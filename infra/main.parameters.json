{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "namePrefix": {
      "value": "netballstats"
    },
    "postgresAdminPassword": {
      "value": "${NETBALL_STATS_POSTGRES_ADMIN_PASSWORD}"
    },
    "postgresApiPassword": {
      "value": "${NETBALL_STATS_POSTGRES_API_PASSWORD}"
    },
    "customFrontendHostname": {
      "value": "${NETBALL_STATS_CUSTOM_FRONTEND_HOSTNAME}"
    }
  }
}
