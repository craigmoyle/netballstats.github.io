{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "namePrefix": {
      "value": "netballstats"
    },
    "postgresAdminPassword": {
      "value": "${NETBALL_STATS_POSTGRES_ADMIN_PASSWORD}"
    },
    "postgresApiPassword": {
      "value": "${NETBALL_STATS_POSTGRES_API_PASSWORD}"
    },
    "customFrontendHostname": {
      "value": "${NETBALL_STATS_CUSTOM_FRONTEND_HOSTNAME}"
    },
    "privatePostgresNetworkingMode": {
      "value": "${NETBALL_STATS_PRIVATE_POSTGRES_NETWORKING_MODE}"
    },
    "virtualNetworkAddressPrefix": {
      "value": "${NETBALL_STATS_VNET_ADDRESS_PREFIX}"
    },
    "containerAppsInfrastructureSubnetPrefix": {
      "value": "${NETBALL_STATS_CONTAINERAPPS_INFRA_SUBNET_PREFIX}"
    },
    "postgresDelegatedSubnetPrefix": {
      "value": "${NETBALL_STATS_POSTGRES_DELEGATED_SUBNET_PREFIX}"
    },
    "postgresPrivateDnsZoneName": {
      "value": "${NETBALL_STATS_POSTGRES_PRIVATE_DNS_ZONE_NAME}"
    },
    "apiImageName": {
      "value": "${SERVICE_API_IMAGE_NAME}"
    }
  }
}
