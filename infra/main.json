{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "4044249053760886613"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "defaultValue": "netballstats",
      "metadata": {
        "description": "Base prefix used for Azure resource names."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the deployment."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags applied to every provisioned resource."
      }
    },
    "staticWebAppSku": {
      "type": "string",
      "defaultValue": "Standard",
      "allowedValues": [
        "Standard"
      ],
      "metadata": {
        "description": "Static Web Apps plan. Standard is required for linked backends."
      }
    },
    "postgresAdminUsername": {
      "type": "string",
      "defaultValue": "netballstatsadmin",
      "metadata": {
        "description": "Admin username for Azure Database for PostgreSQL Flexible Server."
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Admin password for Azure Database for PostgreSQL Flexible Server."
      }
    },
    "postgresApiUsername": {
      "type": "string",
      "defaultValue": "netballstats_api",
      "metadata": {
        "description": "Read-only PostgreSQL user used by the API at runtime."
      }
    },
    "postgresApiPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Password for the read-only PostgreSQL API user."
      }
    },
    "postgresDatabaseName": {
      "type": "string",
      "defaultValue": "netballstats",
      "metadata": {
        "description": "Database name used by the application."
      }
    },
    "postgresVersion": {
      "type": "string",
      "defaultValue": "16",
      "allowedValues": [
        "16",
        "17"
      ],
      "metadata": {
        "description": "PostgreSQL version."
      }
    },
    "postgresSkuName": {
      "type": "string",
      "defaultValue": "Standard_B1ms",
      "metadata": {
        "description": "PostgreSQL compute SKU name."
      }
    },
    "postgresSkuTier": {
      "type": "string",
      "defaultValue": "Burstable",
      "allowedValues": [
        "Burstable",
        "GeneralPurpose",
        "MemoryOptimized"
      ],
      "metadata": {
        "description": "PostgreSQL compute tier."
      }
    },
    "postgresStorageSizeGb": {
      "type": "int",
      "defaultValue": 32,
      "minValue": 32,
      "metadata": {
        "description": "Storage size for PostgreSQL in GB."
      }
    },
    "apiCpu": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "CPU allocation for the API container app."
      }
    },
    "apiMemory": {
      "type": "string",
      "defaultValue": "2Gi",
      "metadata": {
        "description": "Memory allocation for the API container app."
      }
    },
    "apiPort": {
      "type": "int",
      "defaultValue": 8000,
      "metadata": {
        "description": "Container port exposed by the Plumber API."
      }
    },
    "apiMinReplicas": {
      "type": "int",
      "defaultValue": 1,
      "minValue": 1,
      "metadata": {
        "description": "Minimum API replicas."
      }
    },
    "apiMaxReplicas": {
      "type": "int",
      "defaultValue": 2,
      "minValue": 1,
      "metadata": {
        "description": "Maximum API replicas."
      }
    },
    "customFrontendHostname": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional additional frontend hostname to permit through CORS."
      }
    }
  },
  "variables": {
    "resourceToken": "[toLower(uniqueString(resourceGroup().id, parameters('namePrefix')))]",
    "normalizedPrefix": "[toLower(replace(parameters('namePrefix'), '-', ''))]",
    "containerRegistryName": "[take(format('{0}{1}acr', variables('normalizedPrefix'), variables('resourceToken')), 50)]",
    "postgresServerName": "[take(format('{0}-{1}-pg', variables('normalizedPrefix'), variables('resourceToken')), 63)]",
    "staticWebAppName": "[take(format('{0}-web-{1}', parameters('namePrefix'), variables('resourceToken')), 40)]",
    "containerEnvironmentName": "[take(format('{0}-aca-env-{1}', parameters('namePrefix'), variables('resourceToken')), 32)]",
    "containerAppName": "[take(format('{0}-api-{1}', parameters('namePrefix'), variables('resourceToken')), 32)]",
    "keyVaultName": "[take(format('{0}-{1}-kv', variables('normalizedPrefix'), variables('resourceToken')), 24)]",
    "workspaceName": "[take(format('{0}-logs-{1}', parameters('namePrefix'), variables('resourceToken')), 63)]",
    "userAssignedIdentityName": "[take(format('{0}-api-mi-{1}', parameters('namePrefix'), variables('resourceToken')), 64)]",
    "allowAllAzureIpsRuleName": "allow-azure-services",
    "effectiveTags": "[union(parameters('tags'), createObject('azd-env-name', parameters('namePrefix')))]",
    "keyVaultSecretsUserRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
    "acrPullRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2025-07-01",
      "name": "[variables('workspaceName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('effectiveTags')]",
      "properties": {
        "retentionInDays": 30,
        "sku": {
          "name": "PerGB2018"
        }
      }
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2024-11-30",
      "name": "[variables('userAssignedIdentityName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('effectiveTags')]"
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2025-04-01",
      "name": "[variables('containerRegistryName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('effectiveTags')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": false,
        "anonymousPullEnabled": false,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName')), 'AcrPull')]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName')), '2024-11-30').principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('acrPullRoleDefinitionId')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2025-05-01",
      "name": "[variables('keyVaultName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('effectiveTags')]",
      "properties": {
        "enableRbacAuthorization": true,
        "enablePurgeProtection": true,
        "publicNetworkAccess": "Enabled",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "softDeleteRetentionInDays": 90,
        "tenantId": "[tenant().tenantId]"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2025-05-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'postgres-admin-password')]",
      "properties": {
        "value": "[parameters('postgresAdminPassword')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2025-05-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'postgres-api-password')]",
      "properties": {
        "value": "[parameters('postgresApiPassword')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName')), 'KeyVaultSecretsUser')]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName')), '2024-11-30').principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('keyVaultSecretsUserRoleDefinitionId')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2025-08-01",
      "name": "[variables('postgresServerName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('effectiveTags')]",
      "sku": {
        "name": "[parameters('postgresSkuName')]",
        "tier": "[parameters('postgresSkuTier')]"
      },
      "properties": {
        "administratorLogin": "[parameters('postgresAdminUsername')]",
        "administratorLoginPassword": "[parameters('postgresAdminPassword')]",
        "authConfig": {
          "activeDirectoryAuth": "Disabled",
          "passwordAuth": "Enabled"
        },
        "backup": {
          "backupRetentionDays": 7,
          "geoRedundantBackup": "Disabled"
        },
        "createMode": "Create",
        "highAvailability": {
          "mode": "Disabled"
        },
        "network": {
          "publicNetworkAccess": "Enabled"
        },
        "storage": {
          "autoGrow": "Enabled",
          "storageSizeGB": "[parameters('postgresStorageSizeGb')]"
        },
        "version": "[parameters('postgresVersion')]"
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2025-08-01",
      "name": "[format('{0}/{1}', variables('postgresServerName'), parameters('postgresDatabaseName'))]",
      "properties": {
        "charset": "UTF8",
        "collation": "en_US.utf8"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
      "apiVersion": "2025-08-01",
      "name": "[format('{0}/{1}', variables('postgresServerName'), variables('allowAllAzureIpsRuleName'))]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2025-07-01",
      "name": "[variables('containerEnvironmentName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('effectiveTags')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName')), '2025-07-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName')), '2025-07-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2025-07-01",
      "name": "[variables('containerAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName')))]": {}
        }
      },
      "tags": "[union(variables('effectiveTags'), createObject('azd-service-name', 'api'))]",
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "allowInsecure": false,
            "corsPolicy": {
              "allowCredentials": false,
              "allowedHeaders": [
                "Content-Type"
              ],
              "allowedMethods": [
                "GET",
                "OPTIONS"
              ],
              "allowedOrigins": "[if(empty(parameters('customFrontendHostname')), createArray(format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', variables('staticWebAppName')), '2025-03-01').defaultHostname)), createArray(format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', variables('staticWebAppName')), '2025-03-01').defaultHostname), parameters('customFrontendHostname')))]"
            },
            "external": true,
            "targetPort": "[parameters('apiPort')]",
            "traffic": [
              {
                "latestRevision": true,
                "weight": 100
              }
            ],
            "transport": "Auto"
          },
          "registries": [
            {
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName'))]",
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), '2025-04-01').loginServer]"
            }
          ],
          "secrets": [
            {
              "name": "postgres-api-password",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName'))]",
              "keyVaultUrl": "[reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'postgres-api-password'), '2025-05-01').secretUriWithVersion]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "api",
              "image": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
              "env": [
                {
                  "name": "NETBALL_STATS_REPO_ROOT",
                  "value": "/app"
                },
                {
                  "name": "NETBALL_STATS_HOST",
                  "value": "0.0.0.0"
                },
                {
                  "name": "NETBALL_STATS_PORT",
                  "value": "[string(parameters('apiPort'))]"
                },
                {
                  "name": "NETBALL_STATS_ALLOWED_ORIGINS",
                  "value": "[join(if(empty(parameters('customFrontendHostname')), createArray(format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', variables('staticWebAppName')), '2025-03-01').defaultHostname)), createArray(format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', variables('staticWebAppName')), '2025-03-01').defaultHostname), parameters('customFrontendHostname'))), ',')]"
                },
                {
                  "name": "NETBALL_STATS_DB_BACKEND",
                  "value": "postgres"
                },
                {
                  "name": "NETBALL_STATS_DB_HOST",
                  "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName')), '2025-08-01').fullyQualifiedDomainName]"
                },
                {
                  "name": "NETBALL_STATS_DB_PORT",
                  "value": "5432"
                },
                {
                  "name": "NETBALL_STATS_DB_NAME",
                  "value": "[parameters('postgresDatabaseName')]"
                },
                {
                  "name": "NETBALL_STATS_DB_USER",
                  "value": "[parameters('postgresApiUsername')]"
                },
                {
                  "name": "NETBALL_STATS_DB_PASSWORD",
                  "secretRef": "postgres-api-password"
                },
                {
                  "name": "NETBALL_STATS_DB_SSLMODE",
                  "value": "require"
                }
              ],
              "probes": [
                {
                  "type": "Readiness",
                  "httpGet": {
                    "path": "/health",
                    "port": "[parameters('apiPort')]",
                    "scheme": "HTTP"
                  },
                  "initialDelaySeconds": 5,
                  "periodSeconds": 15,
                  "timeoutSeconds": 5
                },
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/health",
                    "port": "[parameters('apiPort')]",
                    "scheme": "HTTP"
                  },
                  "initialDelaySeconds": 15,
                  "periodSeconds": 30,
                  "timeoutSeconds": 5
                }
              ],
              "resources": {
                "cpu": "[parameters('apiCpu')]",
                "memory": "[parameters('apiMemory')]"
              }
            }
          ],
          "scale": {
            "minReplicas": "[parameters('apiMinReplicas')]",
            "maxReplicas": "[parameters('apiMaxReplicas')]"
          }
        }
      },
      "dependsOn": [
        "[extensionResourceId(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName')), 'AcrPull'))]",
        "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvironmentName'))]",
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName'))]",
        "[extensionResourceId(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName')), 'KeyVaultSecretsUser'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'postgres-api-password')]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers/databases', variables('postgresServerName'), parameters('postgresDatabaseName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers/firewallRules', variables('postgresServerName'), variables('allowAllAzureIpsRuleName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]",
        "[resourceId('Microsoft.Web/staticSites', variables('staticWebAppName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('userAssignedIdentityName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2025-03-01",
      "name": "[variables('staticWebAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": "[union(variables('effectiveTags'), createObject('azd-service-name', 'web'))]",
      "sku": {
        "name": "[parameters('staticWebAppSku')]",
        "tier": "[parameters('staticWebAppSku')]"
      },
      "properties": {
        "allowConfigFileUpdates": true,
        "stagingEnvironmentPolicy": "Enabled"
      }
    },
    {
      "type": "Microsoft.Web/staticSites/linkedBackends",
      "apiVersion": "2025-03-01",
      "name": "[format('{0}/{1}', variables('staticWebAppName'), 'api')]",
      "kind": "ContainerApp",
      "properties": {
        "backendResourceId": "[resourceId('Microsoft.App/containerApps', variables('containerAppName'))]",
        "region": "[parameters('location')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', variables('containerAppName'))]",
        "[resourceId('Microsoft.Web/staticSites', variables('staticWebAppName'))]"
      ]
    }
  ],
  "outputs": {
    "staticWebAppHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/staticSites', variables('staticWebAppName')), '2025-03-01').defaultHostname]"
    },
    "staticWebAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', variables('staticWebAppName')), '2025-03-01').defaultHostname)]"
    },
    "apiContainerAppFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2025-07-01').configuration.ingress.fqdn]"
    },
    "containerRegistryLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), '2025-04-01').loginServer]"
    },
    "postgresServerFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName')), '2025-08-01').fullyQualifiedDomainName]"
    },
    "postgresDatabase": {
      "type": "string",
      "value": "[parameters('postgresDatabaseName')]"
    },
    "postgresAdminSecretUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'postgres-admin-password'), '2025-05-01').secretUriWithVersion]"
    },
    "postgresApiUser": {
      "type": "string",
      "value": "[parameters('postgresApiUsername')]"
    }
  }
}